---
import Docs from '../../layouts/Docs.astro';

// Doc structure per qalan-docs/doc-page-layout.md. Reflects master 19:6301:
// чистый label + placeholder; аффиксы — только по смыслу; состояния
// Default/Hover/Focus/Filled/Disabled/Error; Multiline — реально многострочный.
const toc = [
  { id: 'when', label: 'Когда использовать' },
  { id: 'types', label: 'Типы' },
  { id: 'examples', label: 'Примеры в контексте' },
  { id: 'anatomy', label: 'Анатомия' },
  { id: 'states', label: 'Состояния' },
  { id: 'specs', label: 'Характеристики' },
  { id: 'changelog', label: 'Журнал изменений' },
];

const warn = '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 4v5M8 12h.01"/><circle cx="8" cy="8" r="7"/></svg>';
const resize = '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 6L6 14M14 11l-3 3"/></svg>';

// states: caption + the .tf modifier + sample
const states = [
  { mod: '', cap: 'Default', text: 'Введите имя', filled: false, help: 'Как к ребёнку обращаться' },
  { mod: 'tf--hover', cap: 'Hover', text: 'Введите имя', filled: false, help: 'Курсор над полем' },
  { mod: 'tf--focus', cap: 'Focus', text: 'Арманжан', filled: true, help: 'В фокусе, виден курсор' },
  { mod: 'tf--filled', cap: 'Filled', text: 'Арманжан', filled: true, help: 'Заполнено' },
  { mod: 'tf--disabled', cap: 'Disabled', text: 'Недоступно', filled: false, help: 'Поле отключено' },
  { mod: 'tf--error', cap: 'Error', text: 'А', filled: true, error: 'Имя слишком короткое' },
];
---

<Docs title="Text Field" active="text-field" toc={toc}>
  <!-- ===== Header ===== -->
  <section class="prose">
    <h1 class="doc-h1">Text Field</h1>
    <p class="doc-lead">
      Поле ввода: лейбл, контейнер и подсказка снизу. По умолчанию — чистое
      поле с плейсхолдером; аффиксы добавляются только по смыслу. Высота 58,
      радиус 16.
    </p>
    <div class="pill-row">
      <span class="meta-pill"><strong>Платформы:</strong> iOS · Android · Web</span>
      <span class="meta-pill meta-pill--ok"><strong>Статус:</strong> Stable</span>
      <span class="meta-pill"><strong>Обновлено:</strong> 26.06.2026</span>
    </div>
  </section>

  <!-- ===== When to use ===== -->
  <section id="when" class="doc-section prose">
    <h2 class="doc-h2">Когда использовать</h2>
    <p>
      Для свободного текстового ввода: имя, номер телефона, комментарий. Лейбл
      обязателен, подсказка снизу объясняет формат или причину ошибки.
    </p>
    <h3 class="doc-h3">Не использовать</h3>
    <ul>
      <li>Аффиксы (иконка, флаг) — только когда они несут смысл: флаг у телефона, лупа у поиска. Не вешать иконку «для красоты».</li>
      <li>Для выбора из фиксированного набора — это <strong>Dropdown</strong> или <strong>Radio</strong>.</li>
      <li>Для длинного текста — <strong>Multiline</strong>, не однострочное поле.</li>
    </ul>
  </section>

  <!-- ===== Types ===== -->
  <section id="types" class="doc-section">
    <h2 class="doc-h2">Типы</h2>
    <div class="example-grid" style="grid-template-columns:1fr 1fr;">
      <div class="example">
        <div class="example__preview" style="padding:24px; align-items:flex-start;">
          <div class="tf tf--filled" style="width:100%;">
            <label class="tf__label">Имя ребёнка</label>
            <div class="tf__input"><span class="tf__text tf__text--filled">Арманжан</span></div>
          </div>
        </div>
        <div class="example__caption"><b>Text Field</b> — одна строка. <code>.tf</code></div>
      </div>
      <div class="example">
        <div class="example__preview" style="padding:24px; align-items:flex-start;">
          <div class="tf tf--multiline tf--filled" style="width:100%;">
            <label class="tf__label">Комментарий</label>
            <div class="tf__input"><span class="tf__text tf__text--filled" style="white-space:normal;">Рахим путается в порядке действий…</span><span class="tf__resize" set:html={resize}></span></div>
          </div>
        </div>
        <div class="example__caption"><b>Multiline</b> — много строк, ресайз. <code>.tf--multiline</code></div>
      </div>
    </div>
  </section>

  <!-- ===== Examples in context ===== -->
  <section id="examples" class="doc-section">
    <h2 class="doc-h2">Примеры в контексте</h2>
    <p class="doc-body prose">Реальные сценарии Qalan.</p>
    <div class="example-grid" style="grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); margin-top:24px;">
      <div class="example">
        <div class="example__preview" style="padding:24px; align-items:flex-start;">
          <div class="tf tf--filled" style="width:100%;">
            <label class="tf__label">Номер телефона</label>
            <div class="tf__input">
              <span class="tf__affix" style="font-size:20px; line-height:1;">🇰🇿</span>
              <span class="tf__text tf__text--filled">+7 700 123 45 67</span>
            </div>
            <div class="tf__help">Пришлём код подтверждения</div>
          </div>
        </div>
        <div class="example__caption"><b>Вход</b> — флаг-префикс по смыслу (страна).</div>
      </div>
      <div class="example">
        <div class="example__preview" style="padding:24px; align-items:flex-start;">
          <div class="tf" style="width:100%;">
            <label class="tf__label">Имя ребёнка</label>
            <div class="tf__input"><span class="tf__text">Введите имя</span></div>
            <div class="tf__help">Как к ребёнку обращаться</div>
          </div>
        </div>
        <div class="example__caption"><b>Профиль</b> — чистое поле, без иконок.</div>
      </div>
      <div class="example">
        <div class="example__preview" style="padding:24px; align-items:flex-start;">
          <div class="tf tf--multiline tf--filled" style="width:100%;">
            <label class="tf__label">Комментарий ментору</label>
            <div class="tf__input">
              <span class="tf__text tf__text--filled" style="white-space:normal; display:block;">Рахим хорошо решает дроби, но путается в порядке действий. Объясните ещё раз тему «Порядок действий».</span>
              <span class="tf__resize" set:html={resize}></span>
            </div>
          </div>
        </div>
        <div class="example__caption"><b>Менторство</b> — Multiline с реальным текстом.</div>
      </div>
    </div>
  </section>

  <!-- ===== Anatomy ===== -->
  <section id="anatomy" class="doc-section">
    <h2 class="doc-h2">Анатомия</h2>
    <div class="anatomy">
      <div class="stage">
        <div class="tf tf--focus" style="width:340px;">
          <label class="tf__label">Имя ребёнка</label>
          <div class="tf__input"><span class="tf__text tf__text--filled">Арманжан</span></div>
          <div class="tf__help">Как к ребёнку обращаться</div>
        </div>
      </div>
      <ol class="callout-list">
        <li><span class="callout-num">1</span><span><strong>Лейбл</strong> — <code>.tf__label</code>, обязателен; опц. действие справа.</span></li>
        <li><span class="callout-num">2</span><span><strong>Контейнер</strong> — <code>.tf__input</code>: высота 58, радиус 16.</span></li>
        <li><span class="callout-num">3</span><span><strong>Аффикс</strong> (опц.) — <code>.tf__affix</code> 24px: флаг, лупа, счётчик — по смыслу.</span></li>
        <li><span class="callout-num">4</span><span><strong>Подсказка</strong> — <code>.tf__help</code> или <code>.tf__error-msg</code> при ошибке.</span></li>
      </ol>
    </div>
  </section>

  <!-- ===== States ===== -->
  <section id="states" class="doc-section">
    <h2 class="doc-h2">Состояния</h2>
    <div class="example-grid" style="grid-template-columns:repeat(auto-fill,minmax(320px,1fr));">
      {states.map((s) => (
        <div class="example">
          <div class="example__preview" style="padding:24px; align-items:flex-start;">
            <div class:list={['tf', s.mod]} style="width:100%;">
              <label class="tf__label">Имя ребёнка</label>
              <div class="tf__input"><span class:list={['tf__text', { 'tf__text--filled': s.filled }]}>{s.text}</span></div>
              {s.error
                ? <div class="tf__error-msg"><span set:html={warn}></span>{s.error}</div>
                : <div class="tf__help">{s.help}</div>}
            </div>
          </div>
          <div class="example__caption"><b>{s.cap}</b>{s.mod ? <> · <code>.{s.mod}</code></> : <> · <code>.tf</code></>}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== Specs ===== -->
  <section id="specs" class="doc-section">
    <h2 class="doc-h2">Характеристики</h2>
    <div class="table-wrap">
      <table class="ds-table ds-table--spec">
        <thead><tr><th>Свойство</th><th>Значение</th><th>Токен / класс</th></tr></thead>
        <tbody>
          <tr><td>Высота контейнера</td><td>58px (multiline 120)</td><td><code>.tf__input</code></td></tr>
          <tr><td>Радиус</td><td>16px</td><td><code>--radius-l</code></td></tr>
          <tr><td>Текст</td><td>Halvar 18/23</td><td><code>.tf__text</code></td></tr>
          <tr><td>Лейбл / подсказка</td><td>16/21 · 14/18</td><td><code>.tf__label</code> · <code>.tf__help</code></td></tr>
          <tr><td>Focus</td><td>2px brand + свечение brand-100</td><td><code>--border-focus</code></td></tr>
          <tr><td>Error</td><td>фон + рамка critical</td><td><code>--border-status-critical</code></td></tr>
          <tr><td>Аффикс</td><td>24px, опционально</td><td><code>.tf__affix</code></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ===== Changelog ===== -->
  <section id="changelog" class="doc-section">
    <h2 class="doc-h2">Журнал изменений</h2>
    <div class="table-wrap">
      <table class="ds-table ds-table--spec">
        <thead><tr><th>Дата</th><th>Изменение</th><th>Тип</th></tr></thead>
        <tbody>
          <tr><td>26.06.2026</td><td>Док пересобран: аффиксы только по смыслу, Multiline с реальным многострочным текстом, сценарии вход/профиль/менторство.</td><td>Changed</td></tr>
          <tr><td>13.06.2026</td><td>Сборка .tf: 8 состояний + Multiline.</td><td>Added</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</Docs>
