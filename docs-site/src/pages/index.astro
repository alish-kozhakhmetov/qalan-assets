---
import Docs from '../layouts/Docs.astro';
import { nav, navGroups } from '../data/nav';

const blurb: Record<string, string> = {
  foundations: 'Цвета, типографика, отступы, радиусы, размеры и иконки — прямо из токенов.',
  components: 'Кнопки, поля, списки, навигация и клавиатура — на реальных классах base.css.',
  patterns: 'Готовые сборки экранов из компонентов.',
};
---

<Docs title="Главная">
  <section class="prose">
    <h1 class="doc-h1">Qalan Design System</h1>
    <p class="doc-lead">
      Витрина и документация дизайн-системы Qalan. Живые компоненты, токены и
      правила применения — собраны из единого источника: <code>tokens.css</code>,
      <code>base.css</code> и брендовых шрифтов в корне репозитория.
    </p>
    <p class="doc-body" style="margin-top:16px;">
      Каждая страница — это правила «когда использовать», типы и состояния,
      анатомия и примеры в контексте, характеристики и журнал изменений.
    </p>
  </section>

  {navGroups.map((g) => (
    <section class="doc-section" id={g.key}>
      <h2 class="doc-h2">{g.label}</h2>
      <p class="doc-body">{blurb[g.key]}</p>
      <div class="index-grid">
        {nav[g.key].map((item) => (
          item.status === 'ready' ? (
            <a class="index-card" href={`${g.base}/${item.slug}`}>
              <span class="index-card__title">{item.title}</span>
            </a>
          ) : (
            <div class="index-card index-card--soon">
              <span class="index-card__title">{item.title}</span>
              <span class="index-card__status">Скоро</span>
            </div>
          )
        ))}
      </div>
    </section>
  ))}
</Docs>
