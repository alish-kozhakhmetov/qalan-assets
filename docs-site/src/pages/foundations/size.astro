---
import Docs from '../../layouts/Docs.astro';
import { getScale, px } from '../../lib/tokens';

const sizes = getScale('--size-control-');
const LABEL: Record<string, string> = {
  '--size-control-s': 'S — компактные контролы, плотные списки',
  '--size-control-m': 'M — кнопки и поля в карточках',
  '--size-control-l': 'L — основные CTA, поля ввода',
  '--size-control-xl': 'XL — крупные контролы и OTP',
};
---

<Docs title="Size" active="size">
  <section class="prose">
    <h1 class="doc-h1">Size</h1>
    <p class="doc-lead">
      Высоты контролов <code>--size-control-*</code> из <code>tokens.css</code> —
      единая сетка высот для кнопок, полей и списков.
    </p>
  </section>

  <section class="doc-section">
    {sizes.map((s) => (
      <div class="measure-row" style="grid-template-columns:180px 1fr;">
        <div class="measure-meta">
          <b>{s.token.replace('--size-control-', 'control-')}</b>
          <span>{s.value}</span>
        </div>
        <div style="display:flex; align-items:center; gap:16px;">
          <div class="size-bar" style={`height:${px(s.value)}px`}></div>
          <span class="example__caption">{LABEL[s.token] ?? ''}</span>
        </div>
      </div>
    ))}
  </section>
</Docs>
