---
import { nav, navGroups } from '../data/nav';
// Alias shim base.css depends on (--r-*, --font-heading, --*-status-error).
// Must load after tokens.css; bundled CSS is hoisted after the <link>s below.
import '../styles/ds-compat.css';
import '../styles/docs.css';

export interface TocItem { id: string; label: string; }

interface Props {
  title: string;
  /** Active page slug, e.g. 'button' — highlights the sidebar link and
      reveals its in-page section anchors nested underneath. */
  active?: string;
  /** In-page anchors, shown nested under the active sidebar item (single
      navigation surface — no separate right rail). */
  toc?: TocItem[];
}

const { title, active, toc = [] } = Astro.props;
---

<!doctype html>
<html lang="ru" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Qalan DS</title>
    <!-- Single source of truth, synced from repo root by scripts/sync-ds.mjs.
         Order: fonts -> base -> tokens (tokens last so canonical values + dark
         theme win over base.css's legacy embedded :root). docs.css loads last
         via the CSS import above (Astro hoists it into <head>). -->
    <link rel="stylesheet" href="/ds/fonts/fonts.css" />
    <link rel="stylesheet" href="/ds/base.css" />
    <link rel="stylesheet" href="/ds/tokens.css" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('qalan-docs-theme');
          if (t) document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- mobile top bar (shown < 1100px) -->
    <div class="topbar-mobile">
      <button class="hamburger" id="navOpen" aria-label="Открыть навигацию">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
      <a href="/" class="brand__logo">Qalan<span> DS</span></a>
    </div>
    <div class="scrim" id="navScrim"></div>

    <div class="docs">
      <!-- ============================ sidebar ========================== -->
      <aside class="sidebar" id="sidebar">
        <div class="brand">
          <div>
            <a href="/" class="brand__logo">Qalan<span> DS</span></a>
            <div class="brand__sub">Design System</div>
          </div>
          <div class="brand__actions">
            <button class="theme-toggle" id="themeToggle" aria-label="Сменить тему" title="Светлая / тёмная тема">
              <span class="icon-sun"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg></span>
              <span class="icon-moon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg></span>
            </button>
            <button class="sidebar__close" id="navClose" aria-label="Закрыть навигацию">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
            </button>
          </div>
        </div>

        <nav class="nav">
          {navGroups.map((group) => (
            <div class="nav-group">
              <div class="nav-group__label">{group.label}</div>
              {nav[group.key].map((item) => (
                item.status === 'ready' ? (
                  <div>
                    <a
                      href={`${group.base}/${item.slug}`}
                      class:list={['nav-link', { active: item.slug === active }]}
                    >{item.title}</a>
                    {item.slug === active && toc.length > 0 && (
                      <div class="subnav" id="subnav">
                        {toc.map((t) => (
                          <a href={`#${t.id}`} class="subnav__link" data-toc={t.id}>{t.label}</a>
                        ))}
                      </div>
                    )}
                  </div>
                ) : (
                  <span class="nav-link nav-link--soon">
                    <span>{item.title}</span>
                    <span class="nav-pill">скоро</span>
                  </span>
                )
              ))}
            </div>
          ))}
        </nav>
      </aside>

      <!-- ============================ content ========================== -->
      <main class="content" id="docContent">
        <div class="content__inner">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      // ---- theme toggle ----
      (function () {
        var btn = document.getElementById('themeToggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var root = document.documentElement;
          var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('qalan-docs-theme', next); } catch (e) {}
        });
      })();

      // ---- mobile drawer ----
      (function () {
        var sidebar = document.getElementById('sidebar');
        var scrim = document.getElementById('navScrim');
        function open() { sidebar.classList.add('open'); scrim.classList.add('open'); }
        function close() { sidebar.classList.remove('open'); scrim.classList.remove('open'); }
        var o = document.getElementById('navOpen');
        var c = document.getElementById('navClose');
        if (o) o.addEventListener('click', open);
        if (c) c.addEventListener('click', close);
        if (scrim) scrim.addEventListener('click', close);
      })();

      // ---- scroll-spy on the nested in-page anchors (single nav surface) ----
      (function () {
        var links = Array.prototype.slice.call(document.querySelectorAll('.subnav__link[data-toc]'));
        if (!links.length) return;
        var sections = links
          .map(function (l) { return document.getElementById(l.getAttribute('data-toc')); })
          .filter(Boolean);
        function onScroll() {
          var active = sections[0];
          for (var i = 0; i < sections.length; i++) {
            if (sections[i].getBoundingClientRect().top <= 120) active = sections[i];
          }
          links.forEach(function (l) {
            l.classList.toggle('active', active && l.getAttribute('data-toc') === active.id);
          });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
